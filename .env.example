# Copy to .env.local and fill in real values (never commit .env.local)

# CardSight AI — card catalog API (https://cardsight.ai dashboard)
CARDSIGHT_API_KEY=your-cardsight-api-key-here

# Supabase — create a free project at https://supabase.com/dashboard
# Project Settings → API: copy the URL and both keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Service role key is ONLY used by scripts/seed-cards.mjs (server-side, bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
